**B. Agrega esta función al final de tu `admin.js`:**
Respeta exactamente la lógica que me pasaste en `scripts.js`:

```javascript
function consultarDolar() {
    var valor = document.getElementById('txt_valor_usd').value;
    
    // Objeto AJAX idéntico al de tu profesor
    let xhrApi = new XMLHttpRequest();
    xhrApi.open('POST', 'convertir.php', true);
    xhrApi.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
    xhrApi.onreadystatechange = function() {
        if(xhrApi.readyState == 4 && xhrApi.status == 200) {     
            var json = JSON.parse(xhrApi.responseText);    
            // Mostramos el resultado de la API en la pantalla
            document.getElementById("resultado_api").innerText = "Equivale a: $" + parseFloat(json[0].respuesta).toFixed(2) + " MXN";
        }
    };
    xhrApi.send("valor_php=" + valor);   
}

```

